## t/test_zmq.stk — assertion tests for the stryke `Zmq` package.
##
## Uses stryke's native test framework (`assert_*` + `test_run`).
## Requires the cdylib to be loaded — install once with `s pkg install -g .`
## so stryke's FFI bridge dlopens `lib/libstryke_zmq.{dylib,so}` on
## `use Zmq`.
##
## Unlike a broker-backed package, ZeroMQ needs no external service: every
## test runs over `inproc://` transport inside this process. So all
## assertions below fire unconditionally in CI — no creds, no daemon.

use Zmq

# ── cdylib reachable ────────────────────────────────────────────────
val $version = Zmq::version()
assert_ok $version, "Zmq::version returns truthy (cdylib loaded)"

# ── REQ/REP round-trip ──────────────────────────────────────────────
val $rep_ep = "inproc://test-reqrep-$$"
val $rep = Zmq::socket("rep", bind => $rep_ep)
val $req = Zmq::socket("req", connect => $rep_ep)

Zmq::send($req, "ping")
val $server_got = Zmq::recv($rep, timeout_ms => 2000)
assert_eq $server_got, "ping", "rep socket receives the request"

Zmq::send($rep, "pong")
val $client_got = Zmq::recv($req, timeout_ms => 2000)
assert_eq $client_got, "pong", "req socket receives the reply"

Zmq::close($req)
Zmq::close($rep)

# ── PUSH/PULL pipeline ──────────────────────────────────────────────
val $pp_ep = "inproc://test-pushpull-$$"
val $pull = Zmq::socket("pull", bind => $pp_ep)
val $push = Zmq::socket("push", connect => $pp_ep)

Zmq::send($push, "work-1")
Zmq::send($push, "work-2")
val $w1 = Zmq::recv($pull, timeout_ms => 2000)
val $w2 = Zmq::recv($pull, timeout_ms => 2000)
assert_eq $w1, "work-1", "pull receives first pushed item"
assert_eq $w2, "work-2", "pull receives second pushed item in order"

Zmq::close($push)
Zmq::close($pull)

# ── multipart over a PAIR ───────────────────────────────────────────
val $mp_ep = "inproc://test-multipart-$$"
val $a = Zmq::socket("pair", bind => $mp_ep)
val $b = Zmq::socket("pair", connect => $mp_ep)

Zmq::send_multipart($b, ["h", "body", "t"])
val @frames = Zmq::recv_multipart($a, timeout_ms => 2000)
assert_eq scalar(@frames), 3, "recv_multipart returns all three frames"
assert_eq $frames[1], "body", "middle frame preserved"

Zmq::close($a)
Zmq::close($b)

# ── recv timeout returns undef, not a die ───────────────────────────
val $to_ep = "inproc://test-timeout-$$"
val $idle = Zmq::socket("pull", bind => $to_ep)
val $nothing = Zmq::recv($idle, timeout_ms => 100)
assert_ok !defined($nothing), "recv on idle socket returns undef on timeout"
Zmq::close($idle)

# ── poll reports readiness ──────────────────────────────────────────
val $poll_ep = "inproc://test-poll-$$"
val $pr = Zmq::socket("pull", bind => $poll_ep)
val $ps = Zmq::socket("push", connect => $poll_ep)
Zmq::send($ps, "ready")
val $st = Zmq::poll($pr, timeout_ms => 500)
assert_ok $st->{readable}, "poll reports a queued message as readable"
Zmq::close($ps)
Zmq::close($pr)

# ── subscribe / unsubscribe API ─────────────────────────────────────
val $sub_ep = "inproc://test-sub-$$"
val $sub = Zmq::socket("sub", connect => $sub_ep)
val $sub_r = Zmq::subscribe($sub, "topic")
assert_ok $sub_r->{ok}, "subscribe returns ok"
val $unsub_r = Zmq::unsubscribe($sub, "topic")
assert_ok $unsub_r->{ok}, "unsubscribe returns ok"
Zmq::close($sub)

# ── set socket option ───────────────────────────────────────────────
val $set_ep = "inproc://test-set-$$"
val $setsock = Zmq::socket("pub", bind => $set_ep)
val $set_r = Zmq::set($setsock, "sndhwm", 500)
assert_ok $set_r->{ok}, "set sndhwm returns ok"
Zmq::close($setsock)

# ── pure helpers (no socket) ─────────────────────────────────────────
val $tcp = Zmq::parse_endpoint("tcp://127.0.0.1:5555")
assert_eq $tcp->{transport}, "tcp",       "parse_endpoint: transport"
assert_eq $tcp->{host},      "127.0.0.1", "parse_endpoint: host"
assert_eq $tcp->{port},      5555,        "parse_endpoint: numeric port"
assert_ok $tcp->{known_transport},        "parse_endpoint: tcp is known"

val $ipc = Zmq::parse_endpoint("ipc:///tmp/feeds/0")
assert_eq $ipc->{transport}, "ipc",          "parse_endpoint: ipc transport"
assert_eq $ipc->{address},   "/tmp/feeds/0", "parse_endpoint: opaque address"

# build_endpoint: inverse of parse_endpoint.
assert_eq Zmq::build_endpoint(transport => "tcp", host => "127.0.0.1", port => 5555)->{endpoint}, "tcp://127.0.0.1:5555", "build_endpoint: host+port → tcp endpoint"
assert_eq Zmq::build_endpoint(transport => "ipc", address => "/tmp/feeds/0")->{endpoint}, "ipc:///tmp/feeds/0", "build_endpoint: opaque address passes through"
assert_eq Zmq::build_endpoint(transport => "inproc", host => "workers")->{endpoint}, "inproc://workers", "build_endpoint: host without port omits colon"
assert_dies fn { Zmq::build_endpoint(transport => "tcp", host => "") }, "build_endpoint: rejects empty host"

# endpoint_bind_to_connect: rewrite a wildcard bind host to a connectable one.
assert_eq Zmq::endpoint_bind_to_connect("tcp://*:5555")->{endpoint}, "tcp://localhost:5555", "endpoint_bind_to_connect: * → localhost"
assert_eq Zmq::endpoint_bind_to_connect("tcp://0.0.0.0:5555")->{endpoint}, "tcp://localhost:5555", "endpoint_bind_to_connect: 0.0.0.0 → localhost"
assert_eq Zmq::endpoint_bind_to_connect("tcp://localhost:5555")->{changed}, 0, "endpoint_bind_to_connect: concrete host unchanged"
assert_eq Zmq::endpoint_bind_to_connect("ipc:///tmp/s")->{endpoint}, "ipc:///tmp/s", "endpoint_bind_to_connect: non-IP transport passes through"
assert_eq Zmq::endpoint_bind_to_connect("tcp://*:9000", host => "broker")->{endpoint}, "tcp://broker:9000", "endpoint_bind_to_connect: custom connect host"
assert_dies fn { Zmq::endpoint_bind_to_connect("no-scheme") }, "endpoint_bind_to_connect: rejects a malformed endpoint"

# endpoint_connect_to_bind: inverse — rewrite a concrete host to a bind wildcard.
assert_eq Zmq::endpoint_connect_to_bind("tcp://localhost:5555")->{endpoint}, "tcp://*:5555", "endpoint_connect_to_bind: concrete host → *"
assert_eq Zmq::endpoint_connect_to_bind("tcp://broker:9000", host => "0.0.0.0")->{endpoint}, "tcp://0.0.0.0:9000", "endpoint_connect_to_bind: custom bind wildcard"
assert_eq Zmq::endpoint_connect_to_bind("tcp://*:5555")->{changed}, 0, "endpoint_connect_to_bind: already-wildcard host unchanged"
assert_eq Zmq::endpoint_connect_to_bind(Zmq::endpoint_bind_to_connect("tcp://*:5555")->{endpoint})->{endpoint}, "tcp://*:5555", "endpoint_connect_to_bind: round-trips bind_to_connect"
assert_dies fn { Zmq::endpoint_connect_to_bind("no-scheme") }, "endpoint_connect_to_bind: rejects a malformed endpoint"

# valid_endpoint: strict transport-syntax validation.
assert_ok Zmq::valid_endpoint("tcp://127.0.0.1:5555")->{valid}, "valid_endpoint: concrete tcp"
assert_ok Zmq::valid_endpoint("tcp://*:*")->{valid},            "valid_endpoint: bind wildcard host+port"
assert_ok Zmq::valid_endpoint("ipc:///tmp/feeds/0")->{valid},   "valid_endpoint: ipc path"
assert_ok Zmq::valid_endpoint("inproc://workers")->{valid},     "valid_endpoint: inproc name"
assert_eq Zmq::valid_endpoint("no-scheme")->{valid}, 0,         "valid_endpoint: missing :// rejected"
assert_eq Zmq::valid_endpoint("zzz://x")->{valid}, 0,           "valid_endpoint: unknown transport rejected"
assert_eq Zmq::valid_endpoint("tcp://127.0.0.1")->{valid}, 0,   "valid_endpoint: tcp needs a port"
assert_eq Zmq::valid_endpoint("tcp://host:99999")->{valid}, 0,  "valid_endpoint: port out of range"
assert_eq Zmq::valid_endpoint("inproc://")->{valid}, 0,         "valid_endpoint: empty inproc name rejected"
assert_match qr/port/, Zmq::valid_endpoint("tcp://host:abc")->{reason}, "valid_endpoint: reason names the bad port"

assert_eq Zmq::topic_match("weather.", "weather.us.ny"), 1, "topic_match: prefix matches"
assert_eq Zmq::topic_match("sports.", "weather.us"),     0, "topic_match: non-prefix fails"
assert_eq Zmq::topic_match("", "anything"),              1, "topic_match: empty matches all"

# topic_overlaps: whether two prefix subscriptions subsume each other.
val $ov = Zmq::topic_overlaps("weather.", "weather.us")
assert_eq $ov->{overlaps}, 1,   "topic_overlaps: a prefix of b overlaps"
assert_eq $ov->{subsumes}, "a", "topic_overlaps: the shorter (weather.) subsumes the longer"
assert_eq Zmq::topic_overlaps("weather.", "sports.")->{overlaps}, 0, "topic_overlaps: disjoint prefixes do not overlap"
val $eq = Zmq::topic_overlaps("news", "news")
assert_eq $eq->{overlaps}, 1,   "topic_overlaps: identical subscriptions overlap"
assert_eq $eq->{subsumes}, "a", "topic_overlaps: identical → a subsumes"
assert_ok !defined(Zmq::topic_overlaps("a", "b")->{subsumes}), "topic_overlaps: no subsumer when disjoint"

# prune_subscriptions: reduce a subscription set to its minimal cover.
val $pr = Zmq::prune_subscriptions(["weather.", "weather.us", "weather.us.ny", "sports."])
assert_eq join(",", @{ $pr->{pruned} }),  "weather.,sports.",          "prune_subscriptions: keeps the broad subs"
assert_eq join(",", @{ $pr->{removed} }), "weather.us,weather.us.ny",  "prune_subscriptions: drops the subsumed subs"
assert_eq join(",", @{ Zmq::prune_subscriptions(["ab", "a", "b"])->{pruned} }), "a,b", "prune_subscriptions: order-independent subsumption (later broad sub wins)"
assert_eq join(",", @{ Zmq::prune_subscriptions(["", "a", "b.c"])->{pruned} }), "",    "prune_subscriptions: empty subscription collapses the whole set"
assert_eq join(",", @{ Zmq::prune_subscriptions(["x", "x", "y"])->{pruned} }), "x,y",  "prune_subscriptions: duplicates collapse"

# parse_monitor_event: decode a zmq_socket_monitor event id + value + endpoint.
val $ev = Zmq::parse_monitor_event(event => 0x20, value => 7, endpoint => "tcp://0.0.0.0:5555")
assert_eq $ev->{name}, "accepted",                "parse_monitor_event: 0x20 → accepted"
assert_eq $ev->{is_error}, 0,                     "parse_monitor_event: accepted is not an error"
assert_eq $ev->{value_meaning}, "fd",             "parse_monitor_event: accepted value is an fd"
assert_eq $ev->{value}, 7,                        "parse_monitor_event: value passes through"
assert_eq $ev->{endpoint}, "tcp://0.0.0.0:5555",  "parse_monitor_event: endpoint passes through"
val $bf = Zmq::parse_monitor_event(event => 0x10, value => 98)
assert_eq $bf->{name}, "bind_failed",             "parse_monitor_event: 0x10 → bind_failed"
assert_eq $bf->{is_error}, 1,                     "parse_monitor_event: bind_failed is an error"
assert_eq $bf->{value_meaning}, "errno",          "parse_monitor_event: bind_failed value is an errno"
assert_eq Zmq::parse_monitor_event(event => 0x04)->{value_meaning}, "reconnect_interval_ms", "parse_monitor_event: connect_retried value is a reconnect interval"
assert_eq Zmq::parse_monitor_event(event => 0x4000)->{value_meaning}, "zap_status_code",      "parse_monitor_event: handshake_failed_auth value is a ZAP status"
assert_dies fn { Zmq::parse_monitor_event(event => 3) }, "parse_monitor_event: rejects a non-flag id"

# topic_match_any: XPUB set routing — which subscriptions match a topic.
val $tm = Zmq::topic_match_any("weather.us.ny", ["weather.", "sports.", "weather.us"])
assert_eq $tm->{match}, 1,                          "topic_match_any: at least one matched"
assert_eq join(",", @{ $tm->{matched} }), "weather.,weather.us", "topic_match_any: all matches, input order"
assert_eq Zmq::topic_match_any("news.today", ["weather.", "sports."])->{match}, 0, "topic_match_any: no prefix matches"
assert_eq Zmq::topic_match_any("anything", ["x", ""])->{matched}[0], "", "topic_match_any: empty subscription matches all"
assert_eq Zmq::topic_match_any("t", [])->{match}, 0, "topic_match_any: empty set never matches"

# build_subscription / parse_subscription: SUB/XSUB wire frame (leading 1/0 byte).
val $bs = Zmq::build_subscription("weather.us")
assert_eq ord(substr($bs->{frame}, 0, 1)), 1,      "build_subscription: leading byte 1 = subscribe"
assert_eq substr($bs->{frame}, 1), "weather.us",   "build_subscription: topic follows the action byte"
assert_eq ord(substr(Zmq::build_subscription("x", subscribe => 0)->{frame}, 0, 1)), 0, "build_subscription: subscribe => 0 emits the \\x00 unsubscribe byte"
val $ps = Zmq::parse_subscription($bs->{frame})
assert_eq $ps->{subscribe}, 1,                     "parse_subscription: subscribe flag from the leading byte"
assert_eq $ps->{topic}, "weather.us",              "parse_subscription: topic after the action byte"
# Round-trips build_subscription, and the parsed topic feeds topic_match.
val $rt = Zmq::parse_subscription(Zmq::build_subscription("news.")->{frame})
assert_eq $rt->{topic}, "news.",                   "parse_subscription: round-trips build_subscription"
assert_eq Zmq::topic_match($rt->{topic}, "news.today"), 1, "parse_subscription: parsed topic prefix-matches"
assert_dies fn { Zmq::parse_subscription("") },    "parse_subscription: empty frame dies"
assert_dies fn { Zmq::parse_subscription("Xtopic") }, "parse_subscription: a non-0/1 leading byte dies"

val $vt = Zmq::valid_socket_type("PUBLISH")
assert_ok $vt->{valid},               "valid_socket_type: alias is valid"
assert_eq $vt->{canonical}, "pub",    "valid_socket_type: canonicalizes"
assert_ok !Zmq::valid_socket_type("nope")->{valid}, "valid_socket_type: rejects unknown"

val @types = Zmq::socket_types()
assert_eq scalar(@types), 12, "socket_types: twelve canonical names"
assert_ok scalar(grep { $_ eq "router" } @types), "socket_types: includes router"

# socket_peers: ZMQ messaging-pattern compatibility.
assert_eq join(",", Zmq::socket_peers("req")),  "rep,router", "socket_peers: req → rep,router"
assert_eq join(",", Zmq::socket_peers("pub")),  "sub,xsub",   "socket_peers: pub → sub,xsub (alias accepted)"
assert_eq join(",", Zmq::socket_peers("push")), "pull",       "socket_peers: push → pull"
assert_eq join(",", Zmq::socket_peers("pair")), "pair",       "socket_peers: pair ↔ pair"
assert_dies fn { Zmq::socket_peers("nope") }, "socket_peers: rejects an unknown socket type"

# socket_types_compatible: binary peer predicate over the same table.
assert_eq Zmq::socket_types_compatible("req", "rep"),       1, "socket_types_compatible: req ↔ rep"
assert_eq Zmq::socket_types_compatible("PUBLISH", "sub"),   1, "socket_types_compatible: pub ↔ sub (alias accepted)"
assert_eq Zmq::socket_types_compatible("dealer", "router"), 1, "socket_types_compatible: dealer ↔ router"
assert_eq Zmq::socket_types_compatible("req", "pub"),       0, "socket_types_compatible: req ✗ pub"
assert_eq Zmq::socket_types_compatible("push", "push"),     0, "socket_types_compatible: push ✗ push"
assert_dies fn { Zmq::socket_types_compatible("req", "nope") }, "socket_types_compatible: rejects an unknown socket type"

# z85_valid: structural RFC 32 check (length %5, Z85 alphabet).
assert_eq Zmq::z85_valid("HelloWorld")->{valid}, 1, "z85_valid: 10 alnum chars are structurally valid"
assert_eq Zmq::z85_valid("")->{valid},           1, "z85_valid: empty string is valid"
assert_eq Zmq::z85_valid("Hello1")->{valid},     0, "z85_valid: length must be a multiple of 5"
assert_eq Zmq::z85_valid(Zmq::z85_encode("cafebabe", encoding => "hex"))->{valid}, 1, "z85_valid: a real encoded string passes"

# curve_public: re-derive the public key from a secret (companion of curve_keypair).
# Gated on CURVE support since deriving needs libsodium-enabled libzmq.
if (Zmq::has("curve")) {
    val $kp  = Zmq::curve_keypair()
    val $pub = Zmq::curve_public($kp->{secret})
    assert_eq $pub->{public}, $kp->{public}, "curve_public: re-derives the keypair's public key"
}
# The 40-char/Z85 validation runs before the FFI, so a bad secret dies regardless.
assert_dies fn { Zmq::curve_public("too-short") }, "curve_public: rejects a non-40-char secret"

# valid_curve_key: a CURVE key is exactly 40 Z85 chars (non-throwing predicate).
assert_ok Zmq::valid_curve_key("HelloWorld" x 4)->{valid}, "valid_curve_key: 40 Z85 chars is a valid key"
val $vshort = Zmq::valid_curve_key("HelloWorld")
assert_eq $vshort->{valid}, 0,                "valid_curve_key: 10 chars (valid z85) is too short for a CURVE key"
assert_match qr/40/, $vshort->{reason},       "valid_curve_key: reason names the 40-char requirement"
assert_eq Zmq::valid_curve_key(" " x 40)->{valid}, 0, "valid_curve_key: rejects a non-Z85 character (space) at the right length"

# socket_caps: messaging pattern + send/recv directionality (zmq_socket(3)).
val $pubc = Zmq::socket_caps("pub")
assert_eq $pubc->{pattern},  "publish-subscribe", "socket_caps: pub pattern"
assert_eq $pubc->{can_send}, 1,                   "socket_caps: pub is send-only (can_send)"
assert_eq $pubc->{can_recv}, 0,                   "socket_caps: pub is send-only (can_recv false)"
assert_eq Zmq::socket_caps("sub")->{can_send}, 0,   "socket_caps: sub is receive-only"
assert_eq Zmq::socket_caps("push")->{can_recv}, 0,  "socket_caps: push is send-only"
assert_eq Zmq::socket_caps("req")->{pattern},  "request-reply", "socket_caps: req is request-reply"
assert_eq Zmq::socket_caps("xpub")->{can_recv}, 1, "socket_caps: xpub is bidirectional"
assert_eq Zmq::socket_caps("PUBLISH")->{type}, "pub", "socket_caps: alias canonicalized"
assert_dies fn { Zmq::socket_caps("nope") }, "socket_caps: rejects an unknown socket type"

# ── batch-2 surface ──────────────────────────────────────────────────

# socket_type_id: stable libzmq ZMQ_* integers.
assert_eq Zmq::socket_type_id("pair"), 0,  "socket_type_id: pair = 0"
assert_eq Zmq::socket_type_id("req"),  3,  "socket_type_id: req = 3"
assert_eq Zmq::socket_type_id("PUBLISH"), 1, "socket_type_id: alias canonicalizes to pub = 1"
assert_dies fn { Zmq::socket_type_id("nope") }, "socket_type_id: rejects unknown type"

# socket_caps_all: batch form agrees with the per-type call.
val @capsall = Zmq::socket_caps_all()
assert_eq scalar(@capsall), 12, "socket_caps_all: one entry per canonical type"
val ($pubcap) = grep { $_->{type} eq "pub" } @capsall
assert_eq $pubcap->{can_send}, Zmq::socket_caps("pub")->{can_send}, "socket_caps_all: matches socket_caps for pub"

# encoding_names: the framing dimension.
val @encs = Zmq::encoding_names()
assert_eq scalar(@encs), 3, "encoding_names: three encodings"
assert_eq $encs[0]{name}, "utf8", "encoding_names: utf8 first"
assert_eq $encs[1]{binary_safe}, 1, "encoding_names: hex is binary-safe"

# socket_event_names / monitor_event_flag: inverse of parse_monitor_event.
val @evnames = Zmq::socket_event_names()
assert_eq scalar(@evnames), 15, "socket_event_names: fifteen monitor events"
assert_eq Zmq::monitor_event_flag("accepted"), 0x20, "monitor_event_flag: accepted = 0x20"
assert_eq Zmq::parse_monitor_event(event => Zmq::monitor_event_flag("listening"))->{name}, "listening", "monitor_event_flag round-trips parse_monitor_event"
assert_dies fn { Zmq::monitor_event_flag("bogus") }, "monitor_event_flag: rejects unknown event"

# subscription_diff: set difference to reconcile a SUB topic filter.
val $sd = Zmq::subscription_diff(["a", "b", "c"], ["b", "c", "d"])
assert_eq join(",", @{ $sd->{add} }),       "d",   "subscription_diff: add = desired \\ current"
assert_eq join(",", @{ $sd->{remove} }),    "a",   "subscription_diff: remove = current \\ desired"
assert_eq join(",", @{ $sd->{unchanged} }), "b,c", "subscription_diff: unchanged = intersection"

# capabilities: batch form agrees with has() per key.
val $caps = Zmq::capabilities()
assert_ok exists $caps->{curve}, "capabilities: reports curve"
assert_eq $caps->{ipc}, Zmq::has("ipc"), "capabilities: ipc agrees with has(ipc)"

# io_threads: read, bump, restore the shared context's I/O pool.
val $iot = Zmq::io_threads()
assert_ok $iot >= 1, "io_threads: default pool is at least 1"
assert_eq Zmq::io_threads($iot + 1), $iot + 1, "io_threads: set echoes the new size"
Zmq::io_threads($iot)

# events: non-blocking readiness over a real inproc PUSH/PULL pair.
val $ev_ep = "inproc://test-events-$$"
val $ev_pull = Zmq::socket("pull", bind => $ev_ep)
val $ev_push = Zmq::socket("push", connect => $ev_ep)
assert_eq Zmq::events($ev_pull)->{readable}, 0, "events: idle puller is not readable"
Zmq::send($ev_push, "peek")
Zmq::poll($ev_pull, timeout_ms => 500)
assert_ok Zmq::events($ev_pull)->{readable}, "events: queued message → readable (no wait)"
Zmq::close($ev_push)
Zmq::close($ev_pull)

# recv_more: drain trailing frames after a single recv().
val $rm_ep = "inproc://test-recvmore-$$"
val $rm_a = Zmq::socket("pair", bind => $rm_ep)
val $rm_b = Zmq::socket("pair", connect => $rm_ep)
Zmq::send_multipart($rm_b, ["one", "two", "three"])
val $rm_first = Zmq::recv($rm_a, timeout_ms => 2000)
assert_eq $rm_first, "one", "recv_more: recv takes the first frame"
val @rm_rest = Zmq::recv_more($rm_a, timeout_ms => 2000)
assert_eq join(",", @rm_rest), "two,three", "recv_more: drains the trailing frames"
Zmq::close($rm_a)
Zmq::close($rm_b)

# socket_pair: one-call connected inproc PAIR, carries both directions.
val $sp = Zmq::socket_pair()
assert_ok $sp->{a} != $sp->{b}, "socket_pair: distinct handles"
assert_match qr{^inproc://}, $sp->{endpoint}, "socket_pair: default endpoint is inproc"
Zmq::send($sp->{a}, "to-b")
assert_eq Zmq::recv($sp->{b}, timeout_ms => 2000), "to-b", "socket_pair: a → b"
Zmq::send($sp->{b}, "to-a")
assert_eq Zmq::recv($sp->{a}, timeout_ms => 2000), "to-a", "socket_pair: b → a"
Zmq::close($sp->{a})
Zmq::close($sp->{b})

test_run
