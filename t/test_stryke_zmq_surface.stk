## t/test_stryke_zmq_surface.stk — wrapper-completeness pin.
##
## Asserts every public `fn Zmq::name` declared in lib/Zmq.stk is
## reachable via `use` at runtime. Uses `exists &Zmq::name` to probe the
## symbol table without invoking the sub.
##
## Catches:
##   * a wrapper sub deleted from lib/ but still referenced elsewhere
##   * `use Zmq` failing to chase into lib/Zmq.stk
##   * an installed-package entry whose namespace bridge is broken
##
## Permission-free — no service, no daemon. Private helpers (`_` prefix)
## are implementation detail and are NOT asserted.

use Zmq

assert_ok exists &Zmq::version, "Zmq::version exists"
assert_ok exists &Zmq::lib_version, "Zmq::lib_version exists"
assert_ok exists &Zmq::has, "Zmq::has exists"
assert_ok exists &Zmq::socket, "Zmq::socket exists"
assert_ok exists &Zmq::close, "Zmq::close exists"
assert_ok exists &Zmq::bind, "Zmq::bind exists"
assert_ok exists &Zmq::connect, "Zmq::connect exists"
assert_ok exists &Zmq::unbind, "Zmq::unbind exists"
assert_ok exists &Zmq::disconnect, "Zmq::disconnect exists"
assert_ok exists &Zmq::send, "Zmq::send exists"
assert_ok exists &Zmq::send_multipart, "Zmq::send_multipart exists"
assert_ok exists &Zmq::recv, "Zmq::recv exists"
assert_ok exists &Zmq::recv_multipart, "Zmq::recv_multipart exists"
assert_ok exists &Zmq::subscribe, "Zmq::subscribe exists"
assert_ok exists &Zmq::unsubscribe, "Zmq::unsubscribe exists"
assert_ok exists &Zmq::set, "Zmq::set exists"
assert_ok exists &Zmq::get, "Zmq::get exists"
assert_ok exists &Zmq::poll, "Zmq::poll exists"
assert_ok exists &Zmq::poll_many, "Zmq::poll_many exists"
assert_ok exists &Zmq::monitor, "Zmq::monitor exists"
assert_ok exists &Zmq::monitor_recv, "Zmq::monitor_recv exists"
assert_ok exists &Zmq::proxy, "Zmq::proxy exists"
assert_ok exists &Zmq::curve_keypair, "Zmq::curve_keypair exists"
assert_ok exists &Zmq::curve_public, "Zmq::curve_public exists"
assert_ok exists &Zmq::z85_encode, "Zmq::z85_encode exists"
assert_ok exists &Zmq::z85_decode, "Zmq::z85_decode exists"
assert_ok exists &Zmq::z85_valid, "Zmq::z85_valid exists"
assert_ok exists &Zmq::valid_curve_key, "Zmq::valid_curve_key exists"
assert_ok exists &Zmq::request, "Zmq::request exists"

# ── pure helpers (no socket) ──
assert_ok exists &Zmq::parse_endpoint, "Zmq::parse_endpoint exists"
assert_ok exists &Zmq::build_endpoint, "Zmq::build_endpoint exists"
assert_ok exists &Zmq::endpoint_bind_to_connect, "Zmq::endpoint_bind_to_connect exists"
assert_ok exists &Zmq::endpoint_connect_to_bind, "Zmq::endpoint_connect_to_bind exists"
assert_ok exists &Zmq::valid_endpoint, "Zmq::valid_endpoint exists"
assert_ok exists &Zmq::topic_match, "Zmq::topic_match exists"
assert_ok exists &Zmq::topic_overlaps, "Zmq::topic_overlaps exists"
assert_ok exists &Zmq::topic_match_any, "Zmq::topic_match_any exists"
assert_ok exists &Zmq::build_subscription, "Zmq::build_subscription exists"
assert_ok exists &Zmq::parse_subscription, "Zmq::parse_subscription exists"
assert_ok exists &Zmq::valid_socket_type, "Zmq::valid_socket_type exists"
assert_ok exists &Zmq::socket_peers, "Zmq::socket_peers exists"
assert_ok exists &Zmq::socket_types_compatible, "Zmq::socket_types_compatible exists"
assert_ok exists &Zmq::socket_caps, "Zmq::socket_caps exists"
assert_ok exists &Zmq::socket_types, "Zmq::socket_types exists"

test_run
